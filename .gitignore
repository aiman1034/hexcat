# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
build/
dist/

# Secrets — never commit
.env

# HexCat runtime artifacts
*.sqlite3
_scratch/
out/
out_demo*/
_quarantine/
*.hexcat_cache.json

# Phase 3 ledger runtime artifacts — fetched datasheets, caches, generated workbooks.
# Never commit fetched datasheets or caches (manufacturer content + bandwidth).
datasheets/cache/
datasheets/*.html
datasheets/*.htm
datasheets/*.pdf
output/
inputs/live_pns_cisco.csv
# Operator's local reference ledger — proprietary catalog data (7k+ PNs), binary.
# The tool writes the workbook structure from code; it does not read this at runtime.
Cisco_BUILD_LEDGER.xlsx
# Curated transceiver seed — derived (Quellen-Tracker of mineable Cisco optic datasheets)
# from the gitignored BUILD ledger; reproducible, binary. Source list documented in STATUS.md.
Cisco_Transceivers_SEED.xlsx
# Per-brand BUILD seed workbooks — one-row Quellen-Tracker, reproducible from the brand spec +
# its source URL (documented in the spec header); binary, not committed.
MikroTik_BUILD_LEDGER.xlsx
Arista_BUILD_LEDGER.xlsx
Fortinet_BUILD_LEDGER.xlsx
HPE_Aruba_BUILD_LEDGER.xlsx

# Tier-2 headless-browser store — local Chromium for Playwright (~150MB+), never commit.
.playwright-browsers/

# ruflo cross-session memory store (local SQLite + embeddings; never commit)
.swarm/
.hive-mind/
.claude-flow/
.ruflo/
.claude/memory.db
.claude/*.db
.claude/*.db-shm
.claude/*.db-wal
# ruflo vector store (root-level runtime DB)
ruvector.db
ruvector.db-shm
ruvector.db-wal
